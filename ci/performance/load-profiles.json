      "stages": [
        { "duration": "10s", "target_vus": 100 },
        { "duration": "60s", "target_vus": 100 },
        { "duration": "10s", "target_vus": 5 },
        { "duration": "2m", "target_vus": 5 }
      ],
      "think_time_min_s": 0.2,
      "think_time_max_s": 1
    },
    "soak": {
      "description": "Expected load sustained for 1 hour — detect memory leaks and exhaustion",
      "virtual_users": 10,
      "duration": "1h",
      "ramp_up": "1m",
      "think_time_min_s": 1,
      "think_time_max_s": 5,
      "monitoring": {
