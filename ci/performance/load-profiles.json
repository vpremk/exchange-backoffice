        "login": 5,
        "list_documents": 20,
        "upload_document": 8,
        "review_document": 5,
        "health_check": 10
      }
    },
    "stress": {
      "description": "Gradual increase to 5x — find the breaking point",
      "virtual_users_start": 0,
      "virtual_users_max": 50,
      "stages": [
        { "duration": "2m", "target_vus": 10 },
        { "duration": "5m", "target_vus": 25 },
        { "duration": "5m", "target_vus": 50 },
