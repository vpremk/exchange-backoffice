# UAT Environment Configuration
# NOTE: Secrets must be set via GitLab CI/CD variables, not committed here

NODE_ENV=uat
PORT=3001

# Database (connection string set via CI/CD variable: DATABASE_URL)
# DATABASE_URL=postgresql://user:password@host:5432/exchange_backoffice_uat

# Redis (connection string set via CI/CD variable: REDIS_URL)
# REDIS_URL=redis://redis-uat:6379

# MinIO / S3
MINIO_ENDPOINT=minio-uat
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=exchange-documents-uat
# MINIO_ACCESS_KEY and MINIO_SECRET_KEY set via CI/CD variables

# JWT
JWT_EXPIRES_IN=8h
# JWT_SECRET set via CI/CD variable

# CORS
CORS_ORIGIN=https://uat.exchange.example.com

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# File Upload
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=.pdf,.csv,.xlsx,.docx,.png,.jpg

# Queue
QUEUE_CONCURRENCY=3
JOB_TIMEOUT_MS=300000

# Feature Flags
ENABLE_AUDIT_LOG=true
ENABLE_RATE_LIMITING=true
