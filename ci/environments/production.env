# Production Environment Configuration
# NOTE: All secrets MUST be set via GitLab CI/CD variables or vault

NODE_ENV=production
PORT=3001

# Database (connection string set via CI/CD variable: DATABASE_URL)
# DATABASE_URL=postgresql://user:password@host:5432/exchange_backoffice

# Redis (connection string set via CI/CD variable: REDIS_URL)
# REDIS_URL=redis://redis-prod:6379

# MinIO / S3
MINIO_ENDPOINT=s3.example.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_BUCKET=exchange-documents-prod
# MINIO_ACCESS_KEY and MINIO_SECRET_KEY set via CI/CD variables

# JWT
JWT_EXPIRES_IN=4h
# JWT_SECRET set via CI/CD variable

# CORS
CORS_ORIGIN=https://exchange.example.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# File Upload
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=.pdf,.csv,.xlsx,.docx,.png,.jpg

# Queue
QUEUE_CONCURRENCY=5
JOB_TIMEOUT_MS=300000

# Feature Flags
ENABLE_AUDIT_LOG=true
ENABLE_RATE_LIMITING=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# Health Check
HEALTH_CHECK_TIMEOUT_MS=5000
